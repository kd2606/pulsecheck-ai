{
  "expo": {
    "name": "Diagnoverse AI",
    "slug": "pulsecheck-ai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060E1E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#060E1E"
      },
      "package": "com.diagnoverse.ai",
      "versionCode": 4,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "MODIFY_AUDIO_SETTINGS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-av",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Diagnoverse AI to access your photos for health analysis."
        }
      ],
      "expo-font",
      "@react-native-google-signin/google-signin"
    ],
    "scheme": "diagnoverse",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c28b5423-4490-4514-84c3-30e1f5d33737"
      }
    }
  }
}
